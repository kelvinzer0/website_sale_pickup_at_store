<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Default pickup carrier "Ambil di Tempat - Warung Lakku"
        - delivery_type='fixed' (gratis, fixed_price=0)
        - is_pickup=True (flag untuk modul pickup)
        - product = productDelivery product (delivery product standard Odoo)
    -->
    <record id="delivery_carrier_pickup_warung_lakku" model="delivery.carrier">
        <field name="name">Ambil di Tempat — Warung Lakku</field>
        <field name="product_id" ref="delivery.product_product_delivery"/>
        <field name="delivery_type">fixed</field>
        <field name="fixed_price">0.0</field>
        <field name="is_pickup" eval="True"/>
        <field name="active" eval="True"/>
        <!-- Country: Indonesia only (pickup is local) -->
        <field name="country_ids" eval="[(6, 0, [ref('base.id')])]"/>
    </record>
</odoo>
