<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add pickup info banner to sale.order form (only when is_pickup_order=True) -->
    <record id="view_sale_order_form_pickup" model="ir.ui.view">
        <field name="name">sale.order.form.pickup</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <field name="is_pickup_order" invisible="1"/>
                <field name="pickup_ready_at" invisible="1"/>
                <div class="alert alert-info oe_edit_only" role="alert"
                     invisible="not is_pickup_order">
                    <strong>Pickup Order</strong> — Customer akan ambil di toko.
                    <span invisible="not pickup_ready_at">
                        Siap diambil sejak: <field name="pickup_ready_at" readonly="1"/>
                    </span>
                </div>
            </xpath>
        </field>
    </record>
</odoo>

