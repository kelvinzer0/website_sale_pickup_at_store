<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Inject pickup info banner into PAYMENT step (existing behavior).

        Two changes:
        1. Inherit website_sale.payment_delivery_methods to add
           data-is-pickup attribute to the carrier radio input so
           client JS can detect when a pickup carrier is selected.
        2. Inherit website_sale.payment_delivery to insert info banner
           inside the #delivery_carrier div, after the #delivery_method
           list. JS toggles its visibility based on radio selection.
    -->
    <template id="checkout_pickup_mark_carrier_radio" name="Pickup: mark carrier radio"
              inherit_id="website_sale.payment_delivery_methods">
        <xpath expr="//input[@name='delivery_type']" position="attributes">
            <attribute name="t-att-data-is-pickup">delivery.is_pickup and '1' or '0'</attribute>
        </xpath>
    </template>

    <template id="checkout_pickup_info_banner" name="Pickup At Store Info Banner"
              inherit_id="website_sale.payment_delivery">
        <xpath expr="//div[@id='delivery_method']" position="after">
            <t t-set="pickup_addr" t-value="env['ir.config_parameter'].sudo().get_param('website_sale_pickup_at_store.store_address', '') or ''"/>
            <t t-set="pickup_hrs" t-value="env['sale.order']._pickup_hours_display() if 'is_pickup_order' in env['sale.order']._fields else ''"/>
            <div id="pickup_info_banner" class="card mt-3 d-none"
                 style="border-left: 4px solid #16a34a;">
                <div class="card-body">
                    <h6 class="card-title mb-2">
                        <i class="fa fa-store me-2"></i>Ambil di Tempat
                    </h6>
                    <p class="card-text small mb-2">
                        <strong>Gratis ongkir</strong> — pesanan diambil langsung di toko.
                    </p>
                    <div class="small text-muted" id="pickup_store_address_block">
                        <t t-if="pickup_addr">
                            <i class="fa fa-map-marker me-1"></i><t t-out="pickup_addr"/>
                        </t>
                    </div>
                    <div class="small text-muted mt-1" id="pickup_business_hours_block">
                        <t t-if="pickup_hrs">
                            <i class="fa fa-clock-o me-1"></i><t t-out="pickup_hrs"/>
                        </t>
                    </div>
                </div>
            </div>
            <input type="hidden" id="pickup_addr_text" t-att-value="pickup_addr"/>
            <input type="hidden" id="pickup_hrs_text" t-att-value="pickup_hrs"/>
            <script>
                //<![CDATA[
                (function () {
                    "use strict";
                    function updatePickupBanner() {
                        var selected = document.querySelector('input[name="delivery_type"]:checked');
                        var banner = document.getElementById('pickup_info_banner');
                        if (!banner) return;
                        if (selected && selected.dataset && selected.dataset.isPickup === '1') {
                            banner.classList.remove('d-none');
                        } else {
                            banner.classList.add('d-none');
                        }
                    }
                    document.addEventListener('DOMContentLoaded', function () {
                        var radios = document.querySelectorAll('input[name="delivery_type"]');
                        radios.forEach(function (r) {
                            r.addEventListener('change', updatePickupBanner);
                        });
                        updatePickupBanner();
                    });
                })();
                //]]>
            </script>
        </xpath>
    </template>

    <!--
        ============================================================
        PICKUP MODE TOGGLE ON ADDRESS STEP
        ============================================================
        Inject a "Mode Pengiriman" toggle at the TOP of the address
        form so the customer picks delivery vs pickup BEFORE filling
        in any address field. When customer picks "Ambil di Tempat":
          * Hide all address-related fields (.div_street, .div_street2,
            .div_city, .div_zip, .div_country, .div_state_id, .div_vat,
            #div_email, "Kirim ke alamat yang sama" toggle, GPS button)
          * Hide the "Isi alamat Anda atau Sign in" h3 heading
            (no longer relevant in pickup mode)
          * Keep only name + phone visible (still required for the order)
          * Show store info banner (address + business hours)
          * Set hidden input pickup_at_store=1
        When customer picks "Pengiriman ke alamat":
          * Show all fields (default behavior)
          * Set hidden input pickup_at_store=0

        Controller override (controllers/main.py) reads pickup_at_store
        flag and sets order.carrier_id to the pickup carrier.

        XPath note: position="before" on the FIRST <div class="row">
        inside <form class="checkout_autoformat"> inserts the toggle
        as the form's first child — i.e. above the name/email/phone
        row. (position="inside" would have appended at the END of the
        form, after all address fields — that was the previous bug.)
    -->
    <template id="checkout_pickup_mode_toggle" name="Pickup Mode Toggle on Address Step"
              inherit_id="website_sale.address">
        <xpath expr="//form[hasclass('checkout_autoformat')]/div[hasclass('row')][1]" position="before">
            <t t-set="pickup_addr" t-value="env['ir.config_parameter'].sudo().get_param('website_sale_pickup_at_store.store_address', '') or ''"/>
            <t t-set="pickup_hrs" t-value="env['sale.order']._pickup_hours_display() if 'is_pickup_order' in env['sale.order']._fields else ''"/>
            <!-- Wrap toggle in its own row so it spans full width above the form fields -->
            <div class="row">
                <div class="col-lg-12">
                    <!-- Hidden flag submitted with the form -->
                    <input type="hidden" name="pickup_at_store" id="pickup_at_store_input" value="0"/>
                    <!-- P0 audit fix: wrap toggle in a styled card so it visually stands out
                         as a section, not floating buttons. Background subtle gray, full
                         border + accent left bar (primary color). -->
                    <div class="card mb-3" id="pickup_mode_card"
                         style="background: #fafafa; border: 1px solid #e5e7eb; border-left: 4px solid #714B67;">
                        <div class="card-body py-3">
                            <!-- Mode toggle UI (placed at top of form, above address fields) -->
                            <div id="pickup_mode_selector"
                                 t-att-data-store-address="pickup_addr"
                                 t-att-data-store-hours="pickup_hrs">
                                <label class="form-label fw-bold d-block mb-2">Mode Pengiriman</label>
                                <!-- P0 audit fix: btn-group with gap + both buttons rounded
                                     (instead of split radius) for clear visual separation. -->
                                <div class="d-flex gap-2 w-100" role="group" id="pickup_mode_btn_group">
                                    <input type="radio" class="btn-check" name="pickup_mode_radio"
                                           id="pickup_mode_delivery" value="delivery"
                                           checked="checked" autocomplete="off"/>
                                    <label class="btn btn-outline-primary flex-grow-1 rounded-pill" for="pickup_mode_delivery">
                                        <i class="fa fa-truck me-1"></i> Pengiriman ke alamat
                                    </label>
                                    <input type="radio" class="btn-check" name="pickup_mode_radio"
                                           id="pickup_mode_pickup" value="pickup" autocomplete="off"/>
                                    <label class="btn btn-outline-primary flex-grow-1 rounded-pill" for="pickup_mode_pickup">
                                        <i class="fa fa-store me-1"></i> Ambil di Tempat
                                    </label>
                                </div>
                                <small class="text-muted d-block mt-2">
                                    Pilih bagaimana Anda ingin menerima pesanan.
                                </small>
                                <!-- Store info banner (hidden by default, shown when pickup selected).
                                     P0 audit fix: full border + green left accent (was: only left border,
                                     top/right/bottom were 0px none = looked floating). -->
                                <div id="pickup_store_banner" class="card mt-3 d-none"
                                     style="border: 1px solid #e5e7eb; border-left: 4px solid #16a34a;">
                                    <div class="card-body">
                                        <h6 class="card-title mb-2" style="color: #16a34a;">
                                            <i class="fa fa-store me-2"></i>Ambil di Tempat — Warung Lakku
                                        </h6>
                                        <p class="card-text small mb-1">
                                            <strong>Gratis ongkir</strong> — pesanan diambil langsung di toko.
                                        </p>
                                        <div class="small text-muted" id="pickup_store_address_text"></div>
                                        <div class="small text-muted" id="pickup_business_hours_text"></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <style>
                /*<![CDATA[*/
                /* P0 audit fix: bold + larger active button so user instantly sees
                   which mode is selected (was: font-weight 400 same as inactive). */
                #pickup_mode_btn_group .btn-check:checked + .btn {
                    font-weight: 600 !important;
                }
                #pickup_mode_btn_group .btn {
                    font-size: 0.95rem;
                    padding: 0.55rem 1rem;
                }
                @media (max-width: 575.98px) {
                    #pickup_mode_btn_group .btn {
                        font-size: 0.85rem;
                        padding: 0.5rem 0.6rem;
                    }
                    #pickup_mode_btn_group .btn i {
                        display: block;
                        margin: 0 0 2px 0 !important;
                    }
                }
                /*]]>*/
            </style>
            <script>
                //<![CDATA[
                (function () {
                    "use strict";
                    function updatePickupMode() {
                        var pickupRadio = document.getElementById('pickup_mode_pickup');
                        var form = document.querySelector('form.checkout_autoformat');
                        var banner = document.getElementById('pickup_store_banner');
                        var hiddenInput = document.getElementById('pickup_at_store_input');
                        var selector = document.getElementById('pickup_mode_selector');
                        if (!pickupRadio || !form || !banner || !hiddenInput || !selector) {
                            return;
                        }
                        var isPickup = pickupRadio.checked;
                        hiddenInput.value = isPickup ? '1' : '0';

                        // Address-related field selectors to hide/show
                        var addrSelectors = [
                            '.div_street', '.div_street2', '.div_city', '.div_zip',
                            '.div_country', '.div_state_id', '.div_vat',
                            '.div_company_name', '#div_email'
                        ];
                        addrSelectors.forEach(function (sel) {
                            var els = form.querySelectorAll(sel);
                            els.forEach(function (el) {
                                el.style.display = isPickup ? 'none' : '';
                            });
                        });

                        // Also hide the "Kirim ke alamat yang sama" toggle in pickup mode
                        var useSame = document.getElementById('shipping_use_same');
                        if (useSame) {
                            var useSameContainer = useSame.closest('.form-check');
                            if (useSameContainer) {
                                useSameContainer.style.display = isPickup ? 'none' : '';
                            }
                        }

                        // Hide the page heading "Isi alamat Anda atau Sign in"
                        // (or "Billing address" / "Shipping address") when pickup
                        // is selected — it no longer makes sense.
                        var oeCart = document.querySelector('.oe_cart');
                        if (oeCart) {
                            var headings = oeCart.querySelectorAll('h3.mb-3');
                            headings.forEach(function (h) {
                                h.style.display = isPickup ? 'none' : '';
                            });
                        }

                        // Show/hide store info banner
                        if (isPickup) {
                            banner.classList.remove('d-none');
                            var addr = selector.dataset.storeAddress || '';
                            var hrs = selector.dataset.storeHours || '';
                            var addrEl = document.getElementById('pickup_store_address_text');
                            var hrsEl = document.getElementById('pickup_business_hours_text');
                            if (addrEl) {
                                addrEl.innerHTML = addr
                                    ? '<i class="fa fa-map-marker me-1"></i>' + addr
                                    : '';
                            }
                            if (hrsEl) {
                                hrsEl.innerHTML = hrs
                                    ? '<i class="fa fa-clock-o me-1"></i>' + hrs
                                    : '';
                            }
                        } else {
                            banner.classList.add('d-none');
                        }
                    }

                    function setupPickupMode() {
                        var delivery = document.getElementById('pickup_mode_delivery');
                        var pickup = document.getElementById('pickup_mode_pickup');
                        if (delivery) {
                            delivery.addEventListener('change', updatePickupMode);
                        }
                        if (pickup) {
                            pickup.addEventListener('change', updatePickupMode);
                        }
                        updatePickupMode();
                    }

                    if (document.readyState === 'loading') {
                        document.addEventListener('DOMContentLoaded', setupPickupMode);
                    } else {
                        setupPickupMode();
                    }
                    // Re-run after a delay in case the customizer JS reorganizes the DOM
                    setTimeout(setupPickupMode, 500);
                })();
                //]]>
            </script>
        </xpath>
    </template>
</odoo>
